default_platform(:ios)

platform :ios do
  desc "Build and upload a new build to TestFlight (used by .github/workflows/ios-testflight.yml)"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false,
    )

    # Certificate + provisioning profile are imported into the CI keychain
    # by the GitHub Actions workflow before this lane runs.
    increment_build_number(
      build_number: (latest_testflight_build_number(api_key: api_key, initial_build_number: 0) + 1).to_s,
      xcodeproj: "App.xcodeproj",
    )

    # CI has no Apple ID session, only the imported cert + profile — switch
    # the app target to manual signing against exactly those.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: ENV["ASC_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: "Seasonist App Store",
      targets: ["App"],
    )

    # Capacitor 8 uses Swift Package Manager — no CocoaPods workspace;
    # xcodebuild resolves the local CapApp-SPM package during the build.
    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.apporigin.seasonist" => "Seasonist App Store"
        }
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end
end
