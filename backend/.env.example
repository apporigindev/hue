# Seasonist subscription backend — copy to .env and fill in.

NODE_ENV=development
PORT=8080

# Postgres (required in production; omit locally to use an in-memory store)
# DATABASE_URL=postgres://user:pass@host:5432/seasonist

# ── Apple (App Store) ─────────────────────────────────────────────────
APPLE_BUNDLE_ID=com.apporigin.seasonist
# Your numeric App Store app id (App Store Connect → App Information → Apple ID).
# Required for Production verification; may be omitted while testing in Sandbox.
# APPLE_APP_APPLE_ID=1234567890
APPLE_ENVIRONMENT=Sandbox
# Folder with the Apple Root CA certs (download the DER .cer files from
# https://www.apple.com/certificateauthority/ — at least AppleRootCA-G3.cer).
APPLE_ROOT_CERTS_DIR=./certs
APPLE_ENABLE_ONLINE_CHECKS=false

# Optional: App Store Server API key (only if you later call Apple's API).
# APPLE_ISSUER_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── Google Play (optional — Android) ──────────────────────────────────
# GOOGLE_PACKAGE_NAME=com.apporigin.seasonist
# base64 of your Play Developer API service-account JSON
# GOOGLE_SERVICE_ACCOUNT_B64=

# ── App auth ──────────────────────────────────────────────────────────
# Shared secret the app sends as the x-api-key header on verify/entitlement.
# APP_API_KEY=
